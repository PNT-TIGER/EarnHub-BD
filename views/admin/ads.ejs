<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ads - EarnHub Admin</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <aside class="sidebar">
      <div class="sidebar-header"><span class="sidebar-title">EarnHub Admin</span></div>
      <nav class="sidebar-nav">
        <a href="/admin" class="nav-item">Dashboard</a>
        <a href="/admin/users" class="nav-item">Users</a>
        <a href="/admin/withdrawals" class="nav-item">Withdrawals</a>
        <a href="/admin/ads" class="nav-item active">Ads</a>
        <a href="/admin/tasks" class="nav-item">Tasks</a>
        <a href="/admin/giftcodes" class="nav-item">Gift Codes</a>
      </nav>
      <div class="sidebar-footer">
        <span class="admin-badge"><%= admin %></span>
        <a href="/admin/logout" class="nav-item logout">Logout</a>
      </div>
    </aside>

    <main class="main-content">
      <header class="content-header">
        <h1>Ads Management</h1>
      </header>

      <div class="card">
        <div class="card-header">
          <h3>Create New Ad</h3>
        </div>
        <div class="card-body">
          <form method="POST" action="/admin/ads/create" class="form-inline">
            <div class="form-group">
              <label>Title</label>
              <input type="text" name="title" placeholder="Ad title" required class="form-input">
            </div>
            <div class="form-group">
              <label>Description</label>
              <input type="text" name="description" placeholder="Short description" class="form-input">
            </div>
            <div class="form-group">
              <label>Reward ($)</label>
              <input type="number" name="reward" step="0.0001" value="0.0020" required class="form-input">
            </div>
            <div class="form-group">
              <label>URL</label>
              <input type="text" name="url" placeholder="https://..." class="form-input">
            </div>
            <div class="form-group">
              <label>Duration (sec)</label>
              <input type="number" name="duration" value="15" min="5" required class="form-input">
            </div>
            <button type="submit" class="btn btn-primary">Add Ad</button>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h3>All Ads</h3>
        </div>
        <div class="card-body">
          <div class="table-wrap">
            <table class="table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Title</th>
                  <th>Reward</th>
                  <th>Duration</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% ads.forEach(ad => { %>
                <tr>
                  <td>#<%= ad.id %></td>
                  <td><strong><%= ad.title %></strong><br><small><%= ad.description %></small></td>
                  <td class="text-green">$<%= ad.reward.toFixed(4) %></td>
                  <td><%= ad.duration %>s</td>
                  <td><span class="badge badge-<%= ad.status %>"><%= ad.status %></span></td>
                  <td class="actions-cell">
                    <form method="POST" action="/admin/ads/<%= ad.id %>/toggle" class="inline-form">
                      <button class="btn btn-xs <%= ad.status === 'active' ? 'btn-danger' : 'btn-success' %>">
                        <%= ad.status === 'active' ? 'Disable' : 'Enable' %>
                      </button>
                    </form>
                    <form method="POST" action="/admin/ads/<%= ad.id %>/delete" class="inline-form">
                      <button class="btn btn-xs btn-danger">Delete</button>
                    </form>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
