<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Users - EarnHub Admin</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <aside class="sidebar">
      <div class="sidebar-header"><span class="sidebar-title">EarnHub Admin</span></div>
      <nav class="sidebar-nav">
        <a href="/admin" class="nav-item">Dashboard</a>
        <a href="/admin/users" class="nav-item active">Users</a>
        <a href="/admin/withdrawals" class="nav-item">Withdrawals</a>
        <a href="/admin/ads" class="nav-item">Ads</a>
        <a href="/admin/tasks" class="nav-item">Tasks</a>
        <a href="/admin/giftcodes" class="nav-item">Gift Codes</a>
      </nav>
      <div class="sidebar-footer">
        <span class="admin-badge"><%= admin %></span>
        <a href="/admin/logout" class="nav-item logout">Logout</a>
      </div>
    </aside>

    <main class="main-content">
      <header class="content-header">
        <h1>User Management</h1>
        <span class="count-badge"><%= users.length %> users</span>
      </header>

      <div class="card">
        <div class="card-header">
          <h3>All Users</h3>
          <form method="GET" action="/admin/users" class="search-form">
            <input type="text" name="search" placeholder="Search by name, email, phone..." value="<%= search %>" class="search-input">
            <button type="submit" class="btn btn-sm btn-primary">Search</button>
            <% if (search) { %><a href="/admin/users" class="btn btn-sm btn-outline">Clear</a><% } %>
          </form>
        </div>
        <div class="card-body">
          <div class="table-wrap">
            <table class="table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Phone</th>
                  <th>Balance</th>
                  <th>Total Earned</th>
                  <th>Referral Code</th>
                  <th>Status</th>
                  <th>Joined</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach(user => { %>
                <tr>
                  <td>#<%= user.id %></td>
                  <td><strong><%= user.name %></strong></td>
                  <td><%= user.email %></td>
                  <td><%= user.phone %></td>
                  <td class="text-green">$<%= user.balance.toFixed(4) %></td>
                  <td>$<%= user.total_earned.toFixed(4) %></td>
                  <td><code><%= user.referral_code %></code></td>
                  <td><span class="badge badge-<%= user.status %>"><%= user.status %></span></td>
                  <td><%= new Date(user.created_at).toLocaleDateString() %></td>
                  <td class="actions-cell">
                    <form method="POST" action="/admin/users/<%= user.id %>/toggle" class="inline-form">
                      <button type="submit" class="btn btn-xs <%= user.status === 'active' ? 'btn-danger' : 'btn-success' %>">
                        <%= user.status === 'active' ? 'Ban' : 'Unban' %>
                      </button>
                    </form>
                    <form method="POST" action="/admin/users/<%= user.id %>/balance" class="inline-form balance-form">
                      <input type="number" name="balance" value="<%= user.balance %>" class="balance-input" min="0" step="0.0001">
                      <button type="submit" class="btn btn-xs btn-primary">Set</button>
                    </form>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
