<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gift Codes - EarnHub Admin</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <aside class="sidebar">
      <div class="sidebar-header"><span class="sidebar-title">EarnHub Admin</span></div>
      <nav class="sidebar-nav">
        <a href="/admin" class="nav-item">Dashboard</a>
        <a href="/admin/users" class="nav-item">Users</a>
        <a href="/admin/withdrawals" class="nav-item">Withdrawals</a>
        <a href="/admin/ads" class="nav-item">Ads</a>
        <a href="/admin/tasks" class="nav-item">Tasks</a>
        <a href="/admin/giftcodes" class="nav-item active">Gift Codes</a>
      </nav>
      <div class="sidebar-footer">
        <span class="admin-badge"><%= admin %></span>
        <a href="/admin/logout" class="nav-item logout">Logout</a>
      </div>
    </aside>

    <main class="main-content">
      <header class="content-header">
        <h1>Gift Code Management</h1>
      </header>

      <div class="card">
        <div class="card-header">
          <h3>Create New Gift Code</h3>
        </div>
        <div class="card-body">
          <form method="POST" action="/admin/giftcodes/create" class="form-inline">
            <div class="form-group">
              <label>Code (auto if empty)</label>
              <input type="text" name="code" placeholder="e.g. BONUS2026" class="form-input">
            </div>
            <div class="form-group">
              <label>Amount ($)</label>
              <input type="number" name="amount" step="0.01" min="0.01" placeholder="0.50" required class="form-input">
            </div>
            <div class="form-group">
              <label>Max Uses</label>
              <input type="number" name="max_uses" min="1" value="1" required class="form-input">
            </div>
            <button type="submit" class="btn btn-primary">Create Code</button>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h3>All Gift Codes</h3>
        </div>
        <div class="card-body">
          <div class="table-wrap">
            <table class="table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Code</th>
                  <th>Amount</th>
                  <th>Uses</th>
                  <th>Status</th>
                  <th>Created</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% giftCodes.forEach(gc => { %>
                <tr>
                  <td>#<%= gc.id %></td>
                  <td><code class="code-highlight"><%= gc.code %></code></td>
                  <td class="text-green">$<%= gc.amount.toFixed(4) %></td>
                  <td><%= gc.used_count %> / <%= gc.max_uses %></td>
                  <td><span class="badge badge-<%= gc.status %>"><%= gc.status %></span></td>
                  <td><%= new Date(gc.created_at).toLocaleDateString() %></td>
                  <td>
                    <form method="POST" action="/admin/giftcodes/<%= gc.id %>/delete" class="inline-form">
                      <button class="btn btn-xs btn-danger">Delete</button>
                    </form>
                  </td>
                </tr>
                <% }) %>
                <% if (giftCodes.length === 0) { %>
                <tr><td colspan="7" class="text-center">No gift codes yet</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
